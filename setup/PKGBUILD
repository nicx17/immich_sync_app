# Maintainer: Nick <nick@nickcardoso.com>
pkgname=mimick
pkgver=2.0.0
pkgrel=1
pkgdesc="A background daemon to auto-sync photos to Immich on Linux"
arch=('any')
url="https://github.com/nicx17/immich_sync_app"
license=('GPL3')
depends=('python' 'python-requests' 'python-watchdog' 'python-keyring' 'python-pystray' 'python-pillow' 'python-gobject' 'gtk4' 'libadwaita' 'libappindicator-gtk3')
makedepends=('python-setuptools' 'python-build' 'python-installer' 'python-wheel')
source=("$pkgname-$pkgver.tar.gz") # Assuming source is available or will be
sha256sums=('SKIP')

build() {
    cd "$srcdir/$pkgname-$pkgver"
    python -m build --wheel --no-isolation
}

package() {
    cd "$srcdir/$pkgname-$pkgver"
    python -m installer --destdir="$pkgdir" dist/*.whl

    # Install .desktop file
    install -Dm644 setup/mimick.desktop "$pkgdir/usr/share/applications/mimick.desktop"
    
    # Install icons
    install -Dm644 src/assets/icon.svg "$pkgdir/usr/share/icons/hicolor/scalable/apps/mimick.svg"
    install -Dm644 src/assets/icon_128.png "$pkgdir/usr/share/icons/hicolor/128x128/apps/mimick.png"

    # Install metainfo
    install -Dm644 setup/metainfo/com.nickcardoso.mimick.appdata.xml "$pkgdir/usr/share/metainfo/com.nickcardoso.mimick.appdata.xml"
    
    # Install systemd user service (example for user service)
    install -Dm644 setup/mimick.service "$pkgdir/usr/lib/systemd/user/mimick.service"
}
