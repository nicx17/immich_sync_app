[Desktop Entry]
Name=Mimick
Comment=Automatically upload photos to Immich
Exec=mimick
Icon=dev.nicx.mimick
Terminal=false
Type=Application
Categories=Utility;
Actions=Settings;Quit;
Keywords=Photo;Sync;Backup;Immich;
StartupNotify=false
X-GNOME-Autostart-enabled=true
StartupWMClass=dev.nicx.mimick
SingleMainWindow=true

[Desktop Action Settings]
Name=Open Settings
Exec=mimick --settings

[Desktop Action Quit]
Name=Quit Mimick
Exec=mimick --quit
